# WordGod — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional. Defaults to gemini-3-flash-preview if omitted.
GEMINI_MODEL=gemini-3-flash-preview

# ─── Google Ads API (Keyword Planner) ────────────────────────────────────────
# Developer token from: Google Ads → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# OAuth2 credentials from: https://console.cloud.google.com
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here

# Refresh token — generate by running: npx ts-node scripts/generate-refresh-token.ts
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# Google Ads Customer ID (digits only, no dashes)
GOOGLE_ADS_CUSTOMER_ID=1234567890

# MCC Manager Account ID (digits only, no dashes) — required for volume lookup
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_mcc_id_here

# Google Ads API version (default: v21)
# GOOGLE_ADS_API_VERSION=v21
